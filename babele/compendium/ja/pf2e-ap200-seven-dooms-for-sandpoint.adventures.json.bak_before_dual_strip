        "Nualia": {
          "name": "ヌアリア/Nualia",
          "publicNotes": "<p>A beautiful woman with long silver hair, glowing violet eyes, a heavily scarred abdomen, and a demonic left arm that ends in a frightening taloned hand.</p>",
          "privateNotes": "<p>@UUID[JournalEntry.pf2ap20001bonesa.JournalEntryPage.01speakingwith01]{ヌアリアとの会話}</p>",
