        "Ghoul": {
          "name": "グール/Ghoul",
          "publicNotes": "<p>Ghouls are ravenous undead who haunt graveyards and eat corpses.</p>\n<hr />\n<p>Few creatures are more ubiquitous to sinister locations such as lonely graveyards and ruined crypts than the flesh-eating undead known as ghouls.</p>"
        },
        "Glorkus": {
