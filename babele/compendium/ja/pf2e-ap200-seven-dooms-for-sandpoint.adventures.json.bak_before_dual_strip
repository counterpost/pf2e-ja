          "name": "Exit Body",
          "command": "if (!token) {\n  ui.notifications.notify(\"select a token that the new Intellect Devourer spawns from\");\n  return;\n}\n\nconst movePolygon = computeExitBodyCollisionGrid();\n\nconst c = token.center;\nconst s = canvas.scene.dimensions.size;\nconst exitLocations = [];\nfor (let i = -1; i <= 1; i++) {\n  for (let j = -1; j <= 1; j++) {\n    const point = new PIXI.Point(c.x + s * i, c.y + s * j);\n    if (!movePolygon.contains(point.x, point.y)) continue;\n    if (canvas.tokens.placeables.filter((token) => token.bounds.contains(point.x, point.y)).length > 0) continue;\n    const [x0, y0] = canvas.grid.getTopLeft(point.x, point.y);\n    exitLocations.push(new PIXI.Point(x0, y0));\n  }\n}\nif (exitLocations.length === 0) {\n  ui.notifications.notify(\"No space to exit the body\");\n  return;\n}\nconst roll = (await new Roll(`1d${exitLocations.length} - 1`).evaluate()).total;\n\nawait token.actor.update({\"system.attributes.hp.value\": 0})\nawait token.actor.toggleStatusEffect('dead', {overlay: true});\nconst intellectDevourer = fromUuidSync(\n  [\"K7hvZokBDqu61Sws\"].includes(token.actor.id)\n    ? \"Actor.CILo525fbQw8b4W4\"\n    : \"Actor.hxncLW8a85xWnOLG\");\nconst newToken = await intellectDevourer.getTokenDocument({x: exitLocations[roll].x, y: exitLocations[roll].y});\n\n// handle Vekensvok\nif (\n  [\"ecqOHEl8XRfXrQUj\",\"abBSh56KTwnv53PO\",\"Xrwz0r4y4wKiEZfr\",\"4ws2PCdkV5QVEJ49\"]\n    .includes(token.actor.id)\n) {\n  newToken.name = \"Tiluatchek\"\n}\n\ncanvas.scene.createEmbeddedDocuments(\"Token\", [newToken]);\n\nfunction computeExitBodyCollisionGrid() {\n  const c = token.center;\n  const s = canvas.scene.dimensions.size;\n\n  // Compute a rectangle for the engagement bounds\n  const [x0, y0] = canvas.grid.getTopLeft(c.x, c.y);\n  const engagementBounds = new PIXI.Rectangle(x0 - s, y0 - s, 3 * s, 3 * s);\n\n  // Compute a movement polygon which excludes impassible walls\n  const movePolygon = ClockwiseSweepPolygon.create(c, {\n    type: \"move\",\n    boundaryShapes: [engagementBounds]\n  });\n  return movePolygon;\n}"
